# Environment configuration for Weather Data Analysis Pipeline

# Database Configuration
DB_TYPE=sqlite
DB_NAME=weather_data
# For PostgreSQL, uncomment and configure these:
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# Weather API Configuration (Required)
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_API_PROVIDER=openweathermap
WEATHER_API_RATE_LIMIT=60

# Application Configuration
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_DATA_RETENTION_DAYS=90
APP_INGESTION_INTERVAL_MINUTES=60
APP_BATCH_SIZE=100

# Dashboard Configuration
APP_DASHBOARD_HOST=0.0.0.0
APP_DASHBOARD_PORT=8050